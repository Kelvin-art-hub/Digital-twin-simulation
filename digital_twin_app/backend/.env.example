# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-a-long-random-string
APP_DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./digital_twin.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/digital_twin

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Simulation limits
MAX_CONCURRENT_SIMULATIONS=5

# PDF / Reports
REPORTS_DIR=/tmp/digital_twin_reports
